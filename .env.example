# ============================================
# backend/.env.example
# Copy this file to .env and fill in your values
# ============================================

# Application Settings
DEBUG=true
APP_NAME="Amazon Review Intelligence"
APP_VERSION="1.0.0"

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com

# AI/NLP Features
ENABLE_AI=true
ENABLE_EMOTIONS=true

# API Keys (Optional - currently using free services)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=500
# OPENAI_TEMPERATURE=0.4
# OPENAI_TIMEOUT_SECONDS=45
# OPENAI_MAX_RETRIES=2
# HUGGINGFACE_API_KEY=your_huggingface_key_here

# Data Source
DATA_SOURCE=mock  # Options: mock, apify, amazon

# Apify Settings (for production)
APIFY_API_TOKEN=your_apify_token_here
APIFY_ACTOR_ID=your_actor_id_here

# Database (Optional - for production)
DATABASE_URL=sqlite:///./backend/dev.db

# Redis Cache
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=172800
ENABLE_CACHE=true

# Supabase Auth (required for protected APIs)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_AUTH_TIMEOUT_SECONDS=5
SUPABASE_AUTH_CACHE_TTL_SECONDS=60

# Session Auth
SESSION_COOKIE_NAME=ari_session
SESSION_TTL_HOURS=720
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CSRF_COOKIE_NAME=ari_csrf
CSRF_HEADER_NAME=X-CSRF-Token
EMAIL_VERIFY_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_RATE_LIMIT_LOGIN_PER_MINUTE=10
AUTH_RATE_LIMIT_SIGNUP_PER_HOUR=10
AUTH_RATE_LIMIT_PASSWORD_RESET_PER_HOUR=5
FRONTEND_APP_URL=http://localhost:3000

# Export Settings
EXPORT_FOLDER=./exports
MAX_EXPORT_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ============================================
# frontend/.env.example
# Copy this file to .env.local and fill in your values
# ============================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (frontend, required)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# Application Settings
NEXT_PUBLIC_APP_NAME="Amazon Review Intelligence"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=true

# Analytics (Optional)
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_MIXPANEL_TOKEN=your_token_here

# Authentication (Optional - for future implementation)
# NEXT_PUBLIC_AUTH_DOMAIN=your-auth-domain
# NEXT_PUBLIC_AUTH_CLIENT_ID=your-client-id
