# Backend Environment Variables
# Copy this file to .env for local development

# ============= APPLICATION =============
APP_NAME=Amazon Review Intelligence
APP_VERSION=2.0.0
DEBUG=true
ENVIRONMENT=development

# ============= SERVER =============
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============= CORS =============
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app

# ============= APIFY =============
APIFY_API_TOKEN=your_apify_token_here
APIFY_ACTOR_ID=junglee/amazon-reviews-scraper
APIFY_TIMEOUT_SECONDS=300

# ============= AI/NLP =============
ENABLE_AI=true
AI_PROVIDER=free
ENABLE_EMOTIONS=true
ENABLE_THEME_EXTRACTION=true
ENABLE_KEYWORD_CLUSTERING=true
ENABLE_INSIGHTS_GENERATION=true

# ============= DATA SOURCE =============
DATA_SOURCE=apify
MAX_REVIEWS_PER_REQUEST=100
USE_MOCK_FALLBACK=true

# ============= EXPORT =============
EXPORT_FOLDER=/tmp/exports

# ============= FEATURES =============
ENABLE_EXPORT_PDF=true
ENABLE_EXPORT_EXCEL=true

# ============= OPTIONAL: OpenAI =============
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=500
# OPENAI_TEMPERATURE=0.4
# OPENAI_TIMEOUT_SECONDS=45
# OPENAI_MAX_RETRIES=2

# ============= OPTIONAL: Hugging Face =============
# HUGGINGFACE_API_KEY=your_hf_key_here
# HUGGINGFACE_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# ============= OPTIONAL: Database =============
DATABASE_URL=sqlite:///./dev.db
USE_DATABASE=true

# ============= OPTIONAL: Redis Cache =============
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=172800
ENABLE_CACHE=true

# ============= Supabase Auth (required) =============
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_AUTH_TIMEOUT_SECONDS=5
SUPABASE_AUTH_CACHE_TTL_SECONDS=60

# ============= AUTH / SESSION =============
SESSION_COOKIE_NAME=ari_session
SESSION_TTL_HOURS=720
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CSRF_COOKIE_NAME=ari_csrf
CSRF_HEADER_NAME=X-CSRF-Token
EMAIL_VERIFY_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_RATE_LIMIT_LOGIN_PER_MINUTE=10
AUTH_RATE_LIMIT_SIGNUP_PER_HOUR=10
AUTH_RATE_LIMIT_PASSWORD_RESET_PER_HOUR=5
FRONTEND_APP_URL=http://localhost:3000

# ============= SECURITY =============
SECRET_KEY=your-super-secret-key-change-this-in-production
